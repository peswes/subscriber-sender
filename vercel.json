{
  "version": 2,
  "builds": [
    {
      "src": "api/*.js",
      "use": "@vercel/node"
    }
  ],
  "rewrites": [
    {
      "source": "/api/subscribe",
      "destination": "/api/subscribe.js"
    },
   
    {
      "source": "/api/send-newsletter",
      "destination": "/api/send-newsletter.js"
    }
  ]
}

